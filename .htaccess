# Pretty URLs — hide the .html extension.
# 1. If someone hits /contact.html directly, 301 to /contact (canonical).
# 2. /index.html on any path -> strip to the directory.
# 3. Internally rewrite /contact -> /contact.html so the file is served.
RewriteEngine On

# 301 /index.html -> /
RewriteCond %{THE_REQUEST} \s/+(.*)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 301 /foo.html -> /foo  (only when it came from the browser, not from internal rewrite)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internal rewrite /foo -> /foo.html when the file exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Security headers for the immoprox.io marketing site.
# CSP is intentionally omitted — GTM injects scripts dynamically and a
# strict CSP would break tag-manager-driven analytics.
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# Long-cache static assets — PNGs and CSS are stable, content-hashed
# updates aren't applicable here so a moderate 7-day TTL is fine.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 7 days"
  ExpiresByType text/css "access plus 7 days"
</IfModule>
