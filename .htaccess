# Pretty URLs — hide the .html extension.
# 1. If someone hits /contact.html directly, 301 to /contact (canonical).
# 2. /index.html on any path -> strip to the directory.
# 3. Internally rewrite /contact -> /contact.html so the file is served.
RewriteEngine On

# 301 /index.html -> /
RewriteCond %{THE_REQUEST} \s/+(.*)index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 301 /foo.html -> /foo  (only when it came from the browser, not from internal rewrite)
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internal rewrite /foo -> /foo.html when the file exists
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]

# Custom 404 page
ErrorDocument 404 /404.html

# Security headers for the immoprox.io marketing site.
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # Content Security Policy — autorise GTM, Google Analytics, Google Fonts,
  # Supabase (formulaire) et Cal.eu (embed). 'unsafe-inline' sur script-src
  # est requis par GTM pour son bootstrap.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.googletagmanager.com https://googleads.g.doubleclick.net https://www.googleadservices.com https://connect.facebook.net https://*.facebook.net https://analytics.tiktok.com https://*.tiktok.com https://snap.licdn.com https://*.licdn.com https://www.clarity.ms https://*.clarity.ms https://app.cal.eu https://cal.eu; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https: blob:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://stats.g.doubleclick.net https://*.facebook.com https://*.facebook.net https://analytics.tiktok.com https://*.tiktok.com https://px.ads.linkedin.com https://*.licdn.com https://*.clarity.ms https://*.cal.eu; frame-src https://app.cal.eu https://cal.eu https://www.googletagmanager.com https://*.facebook.com https://td.doubleclick.net; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.supabase.co"
</IfModule>

# Cache : règles différenciées par type de contenu
<IfModule mod_expires.c>
  ExpiresActive On
  # HTML : pas de cache (mises à jour immédiates)
  ExpiresByType text/html "access plus 0 seconds"
  # CSS / JS : 1 jour (équilibre fraîcheur / perf)
  ExpiresByType text/css "access plus 1 day"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType application/x-javascript "access plus 1 day"
  # Images : 30 jours
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  # Fonts : 1 an
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  # XML : 1 jour
  ExpiresByType application/xml "access plus 1 day"
</IfModule>

# Compression gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain
  AddOutputFilterByType DEFLATE application/javascript application/xml application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>
